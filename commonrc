# Squeue aliases
#
# jobid, partition, name, user, state, num nodes, dependencies, node list
sq() {
  PAD_WIDTH=6
  REST_WIDTH=42
  MAX_WIDTH=$(stty size | awk '{print $2}')
  REM_WIDTH=$((MAX_WIDTH - REST_WIDTH - PAD_WIDTH))
  NAME_WIDTH=$(( REM_WIDTH > 10 ? REM_WIDTH : 10 ))
  echo $(squeue --format "%.8i %.10P %.${NAME_WIDTH}j %.5u %.8T %.5D %.6E" -S "-D")
}

# Like sq, but only for my jobs
sqm() {
  PAD_WIDTH=6
  REST_WIDTH=37
  MAX_WIDTH=$(stty size | awk '{print $2}')
  REM_WIDTH=$((MAX_WIDTH - REST_WIDTH - PAD_WIDTH))
  NAME_WIDTH=$(( REM_WIDTH > 10 ? REM_WIDTH : 10 ))
  squeue --me --format "%.8i %.10P %.${NAME_WIDTH}j %.8T %.5D %.6E" -S "-D"
}

# jobid, name, state, node list
sqn() {
  PAD_WIDTH=6
  REST_WIDTH=24
  MAX_WIDTH=$(stty size | awk '{print $2}')
  REM_WIDTH=$((MAX_WIDTH - REST_WIDTH - PAD_WIDTH))
  REM_WIDTH=$(( REM_WIDTH > 20 ? REM_WIDTH : 20 ))
  NAME_WIDTH=$((REM_WIDTH / 2))
  NODE_LIST_WIDTH=$((REM_WIDTH - NAME_WIDTH))

  # Node list does not respect size constraints, so we check output width first, and if it exceeds
  # maximum, get rid of non-essential columns (name)

  out=$(squeue --me --format "%.8i %.10P %.${NAME_WIDTH}j %.8T %.${NODE_LIST_WIDTH}N" -S "-D")
  out_width=$(printf '%s\n' "$out" | wc -L)

  if (( out_width > MAX_width )); then
    squeue --me --format "%.8i %.8P %.8T %N" -S "-D"
  else
    echo $out
  fi
}

# Run command on multiple remote nodes
sshrun() {
  COMMAND=$1
  NODES=$2

  if [ -n "$ZSH_VERSION" ]; then
    IFS=',' read -r -A NODE_ARRAY <<< "$NODES" || return 1
  else
    IFS=',' read -r -a NODE_ARRAY <<< "$NODES" || return 1
  fi

  for TARGET in "${NODE_ARRAY[@]}"; do
    echo "Running $COMMAND on $TARGET"
    ssh -t $TARGET $COMMAND
  done
}


# Run command on multiple remote nodes
sshrun_local() {
  COMMAND=$HOME/.local/bin/$1
  NODES=$2

  sshrun $COMMAND $NODES
}

# Run and capture
ctr() {
    if [ "$#" -eq 0 ]; then
        echo "Usage: ctr <command> [args...]"
        return 1
    fi

    local date_str time_str pid logfile cmd ts_start ts_end exit_code

    date_str="$(date '+%Y-%m-%d')"
    time_str="$(date '+%H-%M-%S')"
    pid="$$"

    mkdir -p "logs_ctr/${date_str}" || return 1
    logfile="logs_ctr/${date_str}/${time_str}_${pid}.txt"

    ts_start="$(date '+%Y-%m-%d %H:%M:%S %z')"
    cmd="$(printf '%q ' "$@")"

    {
        printf '================================================================================\n'
        printf 'Timestamp      : %s\n' "$ts_start"
        printf 'User           : %s\n' "$USER"
        printf 'Host           : %s\n' "$(hostname)"
        printf 'PID            : %d\n' "$pid"
        printf 'PPID           : %d\n' "$PPID"
        printf 'PWD            : %s\n' "$PWD"
        printf 'Shell          : %s\n' "$SHELL"
        printf 'Command        : %s\n' "$cmd"
        printf '--------------------------------------------------------------------------------\n'
    } > "$logfile"

    "$@" 2>&1 | tee -a "$logfile"
    exit_code=${PIPESTATUS[0]}

    ts_end="$(date '+%Y-%m-%d %H:%M:%S %z')"

    {
        printf '--------------------------------------------------------------------------------\n'
        printf 'Exit Code      : %d\n' "$exit_code"
        printf 'End Timestamp  : %s\n' "$ts_end"
        printf '================================================================================\n'
    } >> "$logfile"

    return "$exit_code"
}

# Process search with formatted table output
# Usage: psg <pattern> [user]
# No user = all users (shows USER/UID columns)
psg() {
  if [[ "$1" == "-h" || "$1" == "--help" || -z "$1" ]]; then
    echo "Usage: psg <pattern> [user]"
    echo "  pattern  Process name to search"
    echo "  user     Username (default: all users, shows user/uid)"
    return 0
  fi

  local grep_path
  if [[ -n "$ZSH_VERSION" ]]; then
    grep_path=$(whence -p grep 2>/dev/null)
  elif [[ -n "$BASH_VERSION" ]]; then
    grep_path=$(which --skip-alias grep 2>/dev/null || which grep 2>/dev/null)
  fi
  [[ -z "$grep_path" ]] && { echo "grep not found"; return 1; }
  if ! "$grep_path" --version 2>&1 | "$grep_path" -q "GNU"; then
    echo "GNU grep required"; return 1
  fi

  local pattern="$1"
  local ps_args=(-e)
  local show_user=1
  if [[ -n "$2" ]]; then
    ps_args=(-u "$2")
    show_user=0
  fi

  local cols=$(tput cols)
  local inner=$((cols - 4))
  local extra=0
  [[ $show_user -eq 1 ]] && extra=$((16 + 8 + 6))
  local cmd_w=$((inner - 16 - 24 - 12 - 9 - extra))

  local top="┌$(printf '─%.0s' $(seq 1 $((cols - 2))))┐"
  local mid="├$(printf '─%.0s' $(seq 1 $((cols - 2))))┤"
  local bot="└$(printf '─%.0s' $(seq 1 $((cols - 2))))┘"

  echo "$top"
  if [[ $show_user -eq 1 ]]; then
    printf "│ %-16s │ %-8s │ %-16s │ %-24s │ %-12s │ %-${cmd_w}s │\n" \
      "USER" "UID" "PID" "START" "ELAPSED" "COMMAND"
  else
    printf "│ %-16s │ %-24s │ %-12s │ %-${cmd_w}s │\n" \
      "PID" "START" "ELAPSED" "COMMAND"
  fi
  echo "$mid"

  if [[ $show_user -eq 1 ]]; then
    ps "${ps_args[@]}" -o user,uid,pid,lstart,etime,args --no-headers \
      | "$grep_path" -ih "[${pattern:0:1}]${pattern:1}" \
      | sed 's/^ *//' \
      | awk -v cw="$cmd_w" '{
          user=substr($1,1,16); uid=substr($2,1,8); pid=substr($3,1,16)
          start=$4" "$5" "$6" "$7" "$8; etime=substr($9,1,12)
          cmd=""; for(i=10;i<=NF;i++) cmd=cmd (i>10?" ":"") $i
          printf "│ %-16s │ %-8s │ %-16s │ %-24s │ %-12s │ %-"cw"s │\n",
            user, uid, pid, start, etime, substr(cmd,1,cw)
        }'
  else
    ps "${ps_args[@]}" -o pid,lstart,etime,args --no-headers \
      | "$grep_path" -ih "[${pattern:0:1}]${pattern:1}" \
      | sed 's/^ *//' \
      | awk -v cw="$cmd_w" '{
          pid=substr($1,1,16); start=$2" "$3" "$4" "$5" "$6; etime=substr($7,1,12)
          cmd=""; for(i=8;i<=NF;i++) cmd=cmd (i>8?" ":"") $i
          printf "│ %-16s │ %-24s │ %-12s │ %-"cw"s │\n",
            pid, start, etime, substr(cmd,1,cw)
        }'
  fi
  echo "$bot"
}

# Git with retry: 10s timeout, up to 100 retries
ggit() {
  for i in $(seq 1 100); do
    timeout 10 git "$@" && return 0
    echo "ggit: attempt $i failed, retrying..."
  done
  echo "ggit: all 100 attempts failed"
  return 1
}
